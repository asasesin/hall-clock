# Local plain-HTTP preview for Mac / development.
#
# Mirrors the Raspberry Pi appliance (Caddy on port 80 in front of the app) but
# on your own machine, so you can preview the portless http://hallclock.local
# URL exactly as phones see it — no TLS, no certificate warnings, matching the
# Pi's plain-HTTP setup.
#
# Note the app address differs from the Pi: local dev runs the app on TCP
# :8480, while the Pi uses a Unix socket. So this proxies to 127.0.0.1:8480.
#
# Usage
# -----
#   1. Run the app (separate terminal):
#        cd src/hall-clock && go run . -web-dir web
#   2. Run Caddy with this file (binds port 80, so it needs sudo):
#        sudo caddy run --config deploy/local/Caddyfile
#   3. Open:  http://hallclock.local   (or http://localhost)
#
# For hallclock.local to resolve on this Mac, set it up first — either:
#   sudo scutil --set LocalHostName hallclock          # Bonjour, LAN-wide
# or add "127.0.0.1 hallclock.local" to /etc/hosts     # this Mac only

http://hallclock.local, http://localhost {
	reverse_proxy 127.0.0.1:8480
}
