[Unit]
Description=Wall Clock Chromium kiosk
After=graphical.target wall-clock.service
Wants=wall-clock.service

[Service]
Type=simple
User=pi
Group=pi
Environment=DISPLAY=:0
Environment=XAUTHORITY=/home/pi/.Xauthority
ExecStart=/opt/wall-clock/wall-clock-kiosk.sh
Restart=always
RestartSec=3

[Install]
WantedBy=graphical.target

