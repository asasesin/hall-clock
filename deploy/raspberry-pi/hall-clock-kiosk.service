[Unit]
Description=Hall Clock Chromium kiosk
After=graphical.target hall-clock.service caddy.service
Wants=hall-clock.service caddy.service

[Service]
Type=simple
User=pi
Group=pi
Environment=DISPLAY=:0
Environment=XAUTHORITY=/home/pi/.Xauthority
ExecStart=/opt/hall-clock/hall-clock-kiosk.sh
Restart=always
RestartSec=3

[Install]
WantedBy=graphical.target

